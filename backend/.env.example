# ── Firebase (Auth + Firestore) ──
# These are the standard Firebase *web app* config values (used by the Next.js
# frontend to initialize Firebase Auth). The backend only needs
# FIREBASE_PROJECT_ID + a service account (see GOOGLE_APPLICATION_CREDENTIALS
# below) to verify ID tokens and talk to Firestore with the Admin SDK.
# FIREBASE_STORAGE_BUCKET is unused by the backend — file storage is a
# separate, standalone GCS bucket, not Firebase Storage (see GCS_BUCKET_NAME
# below and backend/README.md > "Cloud Storage setup"). It's kept here only
# because the frontend's Firebase web config object expects the key to exist.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── Cloud Storage (NOT Firebase Storage — see backend/README.md > "Cloud
# Storage setup" for how to create this bucket, its CORS config, and the IAM
# role the service account below needs on it) ──
# Used for temporary video/training-image uploads (via signed URLs — see
# POST /uploads/signed-url) and permanent model-artifact storage. Replaced
# Cloudinary, whose free plan capped raw-file uploads at 10MB.
GCS_BUCKET_NAME=

# ── Added for the backend to actually run (not in the original .env.example) ──

# Path to a service-account JSON key. Used for TWO things: (1) firebase-admin,
# to verify ID tokens and read/write Firestore, and (2) gcs_service.py's
# standalone google.cloud.storage.Client, to read/write/sign URLs for the GCS
# bucket above. Generate one in Firebase Console > Project Settings > Service
# Accounts > Generate new private key (Firebase and the underlying GCP project
# share the same IAM — grant this same account the "Storage Object Admin" role
# on GCS_BUCKET_NAME too; see backend/README.md > "Cloud Storage setup").
# If left empty, the backend will try Application Default Credentials, and if
# that also fails, auth/Firestore-backed endpoints will return a clear 503
# instead of the app crashing on startup.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Redis connection string used by RQ for the job queue (jobs + training).
# Local dev default assumes `docker compose up redis` or a local Redis install.
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed origins for CORS (your Next.js dev/prod URLs).
CORS_ORIGINS=http://localhost:3000

# development | production — only affects logging verbosity / docs exposure.
APP_ENV=development
