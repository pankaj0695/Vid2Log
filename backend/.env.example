# ── Cloudinary (temporary video storage + permanent model/report storage) ──
# Upload preset must be UNSIGNED (created in Cloudinary console: Settings > Upload
# > Upload presets). The frontend uploads videos directly to Cloudinary using this
# preset, so the video never passes through our backend/servers.
CLOUDINARY_UPLOAD_PRESET_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase (Auth + Firestore) ──
# These are the standard Firebase *web app* config values (used by the Next.js
# frontend to initialize Firebase Auth). The backend only strictly needs
# FIREBASE_PROJECT_ID + a service account (see GOOGLE_APPLICATION_CREDENTIALS
# below) to verify ID tokens and talk to Firestore with the Admin SDK.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── Added for the backend to actually run (not in the original .env.example) ──

# Path to a Firebase service-account JSON key, needed by firebase-admin to
# verify ID tokens and read/write Firestore from the backend. Generate one in
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
# If left empty, the backend will try Application Default Credentials, and if
# that also fails, auth/Firestore-backed endpoints will return a clear 503
# instead of the app crashing on startup.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Redis connection string used by RQ for the job queue (jobs + training).
# Local dev default assumes `docker compose up redis` or a local Redis install.
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed origins for CORS (your Next.js dev/prod URLs).
CORS_ORIGINS=http://localhost:3000

# development | production — only affects logging verbosity / docs exposure.
APP_ENV=development
