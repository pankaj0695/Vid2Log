# Copy to .env.local and fill in — these are the same Firebase *web app*
# config values documented in backend/.env.example (FIREBASE_*), just
# NEXT_PUBLIC_-prefixed so Next.js bundles them for the browser. None of
# these are secret; Firebase web config is meant to be public.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Base URL of the FastAPI backend (backend/app/main.py). No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional — enables the "Import from Google Drive" button on the training
# and video-processing pages. Leave any of these blank to skip: the button
# just hides itself and local file upload still works. See README.md
# "Google Drive import setup" for how to get all three values.
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_DRIVE_API_KEY=
# Your Google Cloud project NUMBER (not the project ID string, not the OAuth
# client ID) — required for picked files to actually be authorized for
# download, not just visible in the picker. Cloud Console → home dashboard,
# or IAM & Admin → Settings → "Project number".
NEXT_PUBLIC_GOOGLE_DRIVE_APP_ID=
